<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.SongEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0">
                        <Button Click="BackButton_Click" Style="{ThemeResource SubtleButtonStyle}">
                            <FontIcon Glyph="&#xE72B;"/>
                        </Button>
                        <Button Click="SaveButton_Click" Style="{ThemeResource SubtleButtonStyle}" Margin="0,0,8,0">
                            <FontIcon Glyph="&#xE74E;"/>
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="S"/>
                            </Button.KeyboardAccelerators>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="12,0,12,0">
                        <Button Style="{ThemeResource SubtleButtonStyle}" Margin="100,0,100,0">
                            <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF002;"/>
                            <Button.Flyout>
                                <Flyout Placement="Bottom" x:Name="AddCommandBarFlyout">
                                    <StackPanel>
                                        <AppBarButton Label="Insert Capo" Click="InsertCapoButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF004;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton Label="Insert Verse" Click="InsertVerseBlockButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF000;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton Label="Insert Chorus" Click="InsertChorusBlockButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF003;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton Label="Insert Bridge" Click="InsertBridgeBlockButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF006;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton Label="Insert Tab" Click="InsertTabBlockButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF001;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                        <AppBarButton Label="Insert More Tabs" Click="InsertMoreTabBlockButton_Click" VerticalAlignment="Center">
                                            <AppBarButton.Icon>
                                                <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xF005;"/>
                                            </AppBarButton.Icon>
                                        </AppBarButton>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <AutoSuggestBox
                            x:Name="SimilarSoundSearchBox"
                            Width="220"
                            PlaceholderText="Search for rhymes..."
                            TextChanged="SimilarSoundSearchBox_TextChanged"
                            QuerySubmitted="SimilarSoundSearchBox_QuerySubmitted" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                        <Button Style="{ThemeResource SubtleButtonStyle}" Click="DefineNewChordDiagram_Click">
                            <FontIcon FontFamily="/Assets/Fonts/Lyrical.ttf#Lyrical" Glyph="&#xE954;"/>
                        </Button>
                    </StackPanel>
                      
                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Click="SetHelpTextBlock" Style="{ThemeResource SubtleButtonStyle}">
                            <FontIcon Glyph="&#xE897;"/>
                            <Button.Flyout>
                                <Flyout Placement="Bottom" x:Name="HelpCommandFlyout">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled"/>
                                            <Setter Property="MinWidth" Value="700"/>
                                            <Setter Property="MaxWidth" Value="700"/>
                                            <Setter Property="Padding" Value="8"/>
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <StackPanel>
                                        <TextBlock x:Name="HelpTextBlock" Width="600" TextWrapping="NoWrap" TextAlignment="Center" Style="{ThemeResource BaseTextBlockStyle}" />
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button Click="RestoreBackupButton_Click" Style="{ThemeResource SubtleButtonStyle}">
                            <ToolTipService.ToolTip>
                                <ToolTip Content="Restore from backup history"/>
                            </ToolTipService.ToolTip>
                            <FontIcon Glyph="&#xE72C;"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ComboBox x:Name="FontSizeComboBox" Width="110" SelectionChanged="FontSizeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Font: 12" Tag="12" />
                        <ComboBoxItem Content="Font: 14" Tag="14" />
                        <ComboBoxItem Content="Font: 16" Tag="16" />
                        <ComboBoxItem Content="Font: 18" Tag="18" />
                        <ComboBoxItem Content="Font: 20" Tag="20" />
                    </ComboBox>
                    <ComboBox x:Name="DiagramPlacementComboBox" Width="180" SelectionChanged="DiagramPlacementComboBox_SelectionChanged" Padding="12,0,0,0">
                        <x:String>Diagrams: Top</x:String>
                        <x:String>Diagrams: Bottom</x:String>
                    </ComboBox>
                    <Button Content="Pop Out Preview" Click="PopOutPreviewButton_Click" Padding="5,5,6,6"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="SongTitleText" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="0" x:Name="EditorPreviewGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="EditorColumn" Width="*" MinWidth="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="EditorTextBox"
                Grid.Column="0"
                AcceptsReturn="True"
                TextWrapping="NoWrap"
                FontFamily="Consolas"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Top"
                TextChanged="EditorTextBox_TextChanged"
                KeyDown="EditorTextBox_KeyDown"
                LostFocus="EditorTextBox_LostFocus">

                <TextBox.ContextFlyout>
                    <MenuFlyout>
                        <!-- Default edit actions -->
                        <MenuFlyoutItem Text="Undo" Command="{x:Bind UndoCommand}" />
                        <MenuFlyoutItem Text="Redo" Command="{x:Bind RedoCommand}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Cut" Command="{x:Bind CutCommand}" />
                        <MenuFlyoutItem Text="Copy" Command="{x:Bind CopyCommand}" />
                        <MenuFlyoutItem Text="Paste" Command="{x:Bind PasteCommand}" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Select All" Command="{x:Bind SelectAllCommand}" />

                        <!-- Custom editor actions -->
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Insert Verse" Click="InsertVerseBlockButton_Click" />
                        <MenuFlyoutItem Text="Insert Chorus" Click="InsertChorusBlockButton_Click" />
                        <MenuFlyoutItem Text="Insert Bridge" Click="InsertBridgeBlockButton_Click" />
                        <MenuFlyoutItem Text="Insert Tab" Click="InsertTabBlockButton_Click" />
                        <MenuFlyoutItem Text="Insert More Tabs" Click="InsertMoreTabBlockButton_Click" />
                        <MenuFlyoutItem Text="Insert Capo" Click="InsertCapoButton_Click" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Define New Chord" Click="DefineNewChordDiagram_Click" />
                    </MenuFlyout>
                </TextBox.ContextFlyout>
            </TextBox>

            <Border Grid.Column="1" Background="{ThemeResource CardStrokeColorDefaultBrush}">
                <primitives:Thumb
                    x:Name="EditorPreviewSplitter"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    DragDelta="EditorPreviewSplitter_DragDelta" />
            </Border>

            <ScrollViewer x:Name="PreviewPaneScrollViewer" Grid.Column="2" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid x:Name="PreviewContentGrid" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChordDiagramScrollViewer" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ChordDiagramPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" />
                    </ScrollViewer>

                    <RichTextBlock x:Name="PreviewRichTextBlock" Grid.Row="1" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="SongLocationText"
                Opacity="0.7"
                VerticalAlignment="Center"
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="SongStatusText"
                Grid.Column="1"
                VerticalAlignment="Center"
                Opacity="0.7"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</Page>
