<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.SongEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0">
                    <AppBarButton Icon="Save" Label="Save" IsCompact="True" Click="SaveSongButton_Click" Margin="0,0,0,0">
                        <AppBarButton.KeyboardAccelerators>
                            <KeyboardAccelerator Modifiers="Control" Key="S"/>
                        </AppBarButton.KeyboardAccelerators>
                    </AppBarButton>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <AppBarButton Icon="Add" Label="Add" IsCompact="True">
                        <AppBarButton.Flyout>
                            <Flyout Placement="Bottom" x:Name="AddCommandBarFlyout">
                                <StackPanel>
                                    <AppBarButton Label="Insert MetaData" Click="InsertMetadataButton_Click" />
                                    <AppBarButton Label="Insert Chorus" Click="InsertChorusBlockButton_Click" />
                                </StackPanel>
                            </Flyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button>
                        <FontIcon Glyph="&#xE897;"/>
                        <Button.Flyout>
                            <Flyout Placement="Bottom" x:Name="HelpCommandFlyout">
                                <StackPanel>
                                    <TextBlock Text="Help Temp" Style="{ThemeResource BaseTextBlockStyle}" />
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="DiagramPlacementComboBox" Width="180" SelectionChanged="DiagramPlacementComboBox_SelectionChanged" Padding="6,0,0,0">
                    <x:String>Diagrams: Top</x:String>
                    <x:String>Diagrams: Bottom</x:String>
                </ComboBox>
                <Button Content="Pop Out Preview" Click="PopOutPreviewButton_Click" Padding="5,5,6,6"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="EditorTextBox"
                AcceptsReturn="True"
                TextWrapping="NoWrap"
                FontFamily="Consolas"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Top"
                TextChanged="EditorTextBox_TextChanged" />

            <ScrollViewer Grid.Column="1" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid x:Name="PreviewContentGrid" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChordDiagramScrollViewer" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ChordDiagramPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" />
                    </ScrollViewer>

                    <RichTextBlock x:Name="PreviewRichTextBlock" Grid.Row="1" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
