<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.SongEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <AppBarButton Icon="Save" Label="Save" IsCompact="True" Click="SaveSongButton_Click">
                    <AppBarButton.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="S"/>
                    </AppBarButton.KeyboardAccelerators>
                </AppBarButton>
                <DropDownButton Content="Add" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Insert MetaData" Click="InsertMetadataButton_Click"/>
                            <MenuFlyoutItem Text="Insert Chorus" Click="InsertChorusBlockButton_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <AppBarButton Icon="Remove" IsCompact="True" Click="CloseCurrentDocumentButton_Click" HorizontalAlignment="Right">
                    
                </AppBarButton>
                <!--<Button Content="Insert Meta Data" Click="InsertMetadataButton_Click" HorizontalAlignment="Right"/>
                <Button Content="Insert Chorus Block" Click="InsertChorusBlockButton_Click" HorizontalAlignment="Right"/> -->
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <ComboBox x:Name="DiagramPlacementComboBox" Width="180" SelectionChanged="DiagramPlacementComboBox_SelectionChanged">
                    <x:String>Diagrams: Top</x:String>
                    <x:String>Diagrams: Bottom</x:String>
                </ComboBox>
                <Button Content="Pop Out Preview" Click="PopOutPreviewButton_Click" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="EditorTextBox"
                AcceptsReturn="True"
                TextWrapping="NoWrap"
                FontFamily="Consolas"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Top"
                TextChanged="EditorTextBox_TextChanged" />

            <ScrollViewer Grid.Column="1" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid x:Name="PreviewContentGrid" RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ChordDiagramScrollViewer" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ChordDiagramPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" />
                    </ScrollViewer>

                    <RichTextBlock x:Name="PreviewRichTextBlock" Grid.Row="1" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
