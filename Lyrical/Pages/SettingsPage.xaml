<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Lyrical.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="Settings"
            Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Theme section -->
        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1"
            Margin="0,12,0,0">
            <StackPanel Spacing="8" Margin="0,0,0,24">
                <TextBlock
                    Text="Appearance"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Choose how Lyrical looks. System follows your Windows colour mode."
                    Opacity="0.7"
                    TextWrapping="Wrap" />
                <RadioButtons
                    x:Name="ThemeRadioButtons"
                    SelectionChanged="ThemeRadioButtons_SelectionChanged">
                    <RadioButton Content="System" Tag="Default" />
                    <RadioButton Content="Light"  Tag="Light" />
                    <RadioButton Content="Dark"   Tag="Dark" />
                </RadioButtons>
            </StackPanel>
        </Border>
        

        <!-- Editor auto-save section -->
        <Border
            Grid.Row="2"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1"
            Margin="0,0,0,0">
            <StackPanel Spacing="8" Margin="0,0,0,24">
                <TextBlock
                    Text="Editor Auto Save"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Configure when the editor saves automatically. Delay is in seconds."
                    Opacity="0.7"
                    TextWrapping="Wrap" />

                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        x:Name="AutoSaveModeComboBox"
                        SelectionChanged="AutoSaveModeComboBox_SelectionChanged">
                        <x:String>Off</x:String>
                        <x:String>On Focus Change</x:String>
                        <x:String>After Delay</x:String>
                    </ComboBox>

                    <NumberBox
                        x:Name="AutoSaveDelayNumberBox"
                        Grid.Column="1"
                        Minimum="1"
                        Maximum="120"
                        SmallChange="1"
                        SpinButtonPlacementMode="Inline"
                        ValueChanged="AutoSaveDelayNumberBox_ValueChanged" />

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="seconds (used for After Delay mode)"
                        Opacity="0.7" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Song library section -->
        <Border
            Grid.Row="3"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="8" Margin="0,0,0,24">
                <TextBlock
                    Text="Song Library"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Choose where songs are saved. Shared works well with a OneDrive shared folder for collaboration."
                    Opacity="0.7"
                    TextWrapping="Wrap" />

                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox
                        x:Name="LibraryModeComboBox"
                        SelectionChanged="LibraryModeComboBox_SelectionChanged">
                        <x:String>Local (Private)</x:String>
                        <x:String>Shared (OneDrive)</x:String>
                    </ComboBox>

                    <Button
                        Grid.Column="1"
                        Content="Choose Local Folder"
                        Click="ChooseLocalFolderButton_Click" />

                    <TextBlock
                        x:Name="LocalFolderText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Opacity="0.7"
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        Content="Choose Shared Folder"
                        Click="ChooseSharedFolderButton_Click" />

                    <TextBlock
                        x:Name="SharedFolderText"
                        Grid.Row="1"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Opacity="0.7"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Add chord section -->
        <Border
            Grid.Row="4"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="8" Margin="0,0,0,24">
                <TextBlock
                    Text="Custom Chord Definitions"
                    Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Enter ChordPro define directives, one per line. Example:&#x0a;{define: B base-fret 1 frets 1 1 3 3 3 1}"
                    Opacity="0.7"
                    TextWrapping="Wrap" />

                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="DefineInputBox"
                        PlaceholderText="{}{define: chordname base-fret 1 frets x 3 2 0 1 0}"
                        FontFamily="Consolas"
                        KeyDown="DefineInputBox_KeyDown" />

                    <Button
                        x:Name="AddSaveButton"
                        Grid.Column="1"
                        Content="Add"
                        VerticalAlignment="Stretch"
                        Click="AddSaveButton_Click" />

                    <Button
                        x:Name="CancelEditButton"
                        Grid.Column="2"
                        Content="Cancel"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed"
                        Click="CancelEditButton_Click" />
                </Grid>

                <TextBlock
                    x:Name="ErrorText"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    Visibility="Collapsed"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Chord list -->
        <Border
            Grid.Row="5"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
            BorderThickness="0,0,0,1">
            <ListView
                x:Name="ChordListView"
                Grid.Row="5"
                ItemsSource="{x:Bind Chords}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CustomChordDefinition">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Text="{x:Bind Name}"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                VerticalAlignment="Center"
                                MinWidth="80" />

                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind RawDirective}"
                                FontFamily="Consolas"
                                VerticalAlignment="Center"
                                Opacity="0.7"
                                TextTrimming="CharacterEllipsis" />

                            <Button
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Click="EditChordButton_Click"
                                CommandParameter="{x:Bind}">
                                <SymbolIcon Symbol="Edit" />
                            </Button>

                            <Button
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Click="RemoveChordButton_Click"
                                CommandParameter="{x:Bind}">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
