<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.PreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="0">
                <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
                <Button Content="Close Preview" Click="CloseButton_Click" /> 
                
                <!-- Grid.Column="1" -->
                <StackPanel
                    x:Name="AutoScrollControlsPanel"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="350,0,350,0"
                    Visibility="Collapsed">
                    <Button x:Name="AutoScrollButton" Click="AutoScrollButton_Click" Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Play"/>
                            <TextBlock Text="Autoscroll"/>
                        </StackPanel>
                    </Button>
                    <Slider
                        x:Name="AutoScrollSpeedSlider"
                        Width="140"
                        Minimum="0.5"
                        Maximum="2"
                        StepFrequency="0.5"
                        Value="1"
                        Padding="8"
                        ValueChanged="AutoScrollSpeedSlider_ValueChanged" />
                        <TextBlock x:Name="AutoScrollSpeedText" VerticalAlignment="Center" Text="1x" />
                </StackPanel>

                <ComboBox
                    x:Name="PreviewFontSizeComboBox"
                    Grid.Column="2"
                    Width="110"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,0,0"
                    SelectionChanged="PreviewFontSizeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Font: 12" Tag="12" />
                    <ComboBoxItem Content="Font: 14" Tag="14" />
                    <ComboBoxItem Content="Font: 16" Tag="16" />
                    <ComboBoxItem Content="Font: 18" Tag="18" />
                    <ComboBoxItem Content="Font: 20" Tag="20" />
                </ComboBox>
            </StackPanel>

            

            <TextBlock
                Grid.Column="3"
                HorizontalAlignment="Right"
                Text="Preview"
                Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <ScrollViewer
            x:Name="PreviewScrollViewer"
            Grid.Row="1"
            Padding="12"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Background="{ThemeResource CardBackgroundFillColorSecondary}"
            PointerWheelChanged="PreviewScrollViewer_UserScrollDetected"
            PointerPressed="PreviewScrollViewer_UserScrollDetected">
            <Grid x:Name="PreviewContentGrid" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="ChordDiagramScrollViewer" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ChordDiagramPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom"/>
                </ScrollViewer>

                <RichTextBlock x:Name="PreviewRichTextBlock" Grid.Row="1" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
