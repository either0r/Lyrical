<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.PreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Content="Back" Click="BackButton_Click" />
            <Button Grid.Column="1" Content="Close Preview" Click="CloseButton_Click" />
            <TextBlock
                Grid.Column="2"
                HorizontalAlignment="Right"
                Text="Preview"
                Style="{StaticResource SubtitleTextBlockStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid x:Name="PreviewContentGrid" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="ChordDiagramScrollViewer" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ChordDiagramPanel" Orientation="Horizontal" Spacing="10" VerticalAlignment="Bottom" />
                </ScrollViewer>

                <RichTextBlock x:Name="PreviewRichTextBlock" Grid.Row="1" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
