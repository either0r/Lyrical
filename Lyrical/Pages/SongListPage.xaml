<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Lyrical.Pages.SongListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Lyrical.Models"
    xmlns:converters="using:Lyrical.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:CreatorToBrushConverter x:Key="CreatorToBrushConverter" />
        <converters:CreatorToForegroundBrushConverter x:Key="CreatorToForegroundBrushConverter" />
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Lyrical Notebook"
                Style="{StaticResource TitleTextBlockStyle}" />

            <Image
                Grid.Column="1"
                Source="/Assets/Images/Logo.svg"
                Height="48" />

            <Button
                Grid.Column="2"
                Content="Open File"
                Click="OpenFileButton_Click" />

            <Button
                x:Name="NewSongButton"
                Grid.Column="3"
                Content="New Song"
                Click="NewSongButton_Click" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Song Books"
                            Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            Text="Create structured Song Books ie: MySongs, Unfinished, Production etc."
                            Opacity="0.7"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Content="New Folder"
                            Click="NewFolderButton_Click" />
                        <Button
                            x:Name="RenameFolderButton"
                            Content="Rename"
                            IsEnabled="False"
                            Click="RenameFolderButton_Click" />
                        <Button
                            x:Name="DeleteFolderButton"
                            Content="Delete"
                            IsEnabled="False"
                            Click="DeleteFolderButton_Click" />
                    </StackPanel>

                    <TreeView
                        x:Name="FolderTreeView"
                        Grid.Row="2"
                        AllowDrop="True"
                        SelectionMode="Single"
                        SelectionChanged="FolderTreeView_SelectionChanged"
                        DragOver="FolderTreeView_DragOver"
                        Drop="FolderTreeView_Drop" />
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                CornerRadius="12"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Songs"
                            Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            x:Name="SelectedFolderText"
                            Opacity="0.85"
                            Text="Library Root"
                            TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{x:Bind Breadcrumbs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock
                                            Text="{Binding Separator}"
                                            Opacity="0.5" />
                                        <Button
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="BreadcrumbButton_Click"
                                            CommandParameter="{Binding}">
                                            <TextBlock
                                                Text="{Binding DisplayName}"
                                                Opacity="0.7"
                                                TextWrapping="Wrap" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            x:Name="SongCountText"
                            Opacity="0.6"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <RadioButtons
                        x:Name="SongScopeRadioButtons"
                        Grid.Row="1"
                        MaxColumns="2"
                        SelectionChanged="SongScopeRadioButtons_SelectionChanged">
                        <RadioButton Content="Selected folder" />
                        <RadioButton Content="Folder + subfolders" />
                    </RadioButtons>

                    <TextBlock
                        x:Name="EmptyStateText"
                        Grid.Row="2"
                        Opacity="0.7"
                        TextWrapping="Wrap" />

                    <InfoBar
                        x:Name="FolderHintInfoBar"
                        Grid.Row="3"
                        IsOpen="False"
                        IsClosable="False"
                        Severity="Informational"
                        Title="Tip"
                        Message="Select a folder to create songs directly inside it." />

                    <ListView
                        x:Name="SongListView"
                        Grid.Row="4"
                        ItemsSource="{x:Bind FilteredSongs}"
                        IsItemClickEnabled="True"
                        SelectionMode="Single"
                        CanDragItems="True"
                        DragItemsStarting="SongListView_DragItemsStarting"
                        DragItemsCompleted="SongListView_DragItemsCompleted"
                        ItemClick="SongListView_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SongDocument">
                                <Border
                                    Padding="8"
                                    CornerRadius="8"
                                    Margin="0,0,0,8"
                                    Background="{Binding CreatedBy, Converter={StaticResource CreatorToBrushConverter}}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Text="{x:Bind Title}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Text="{x:Bind CreatedBy}"
                                                Opacity="0.75"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Text="{x:Bind LastModifiedText}"
                                                Opacity="0.6"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}" />
                                            <TextBlock
                                                Grid.Row="3"
                                                Text="{x:Bind FolderDisplayName}"
                                                Opacity="0.6"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}" />
                                        </Grid>

                                        <StackPanel
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                            <Button
                                                Content="Rename"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}"
                                                Click="RenameSongButton_Click"
                                                CommandParameter="{x:Bind}" />
                                            <Button
                                                Content="Move"
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}"
                                                Click="MoveSongButton_Click"
                                                CommandParameter="{x:Bind}" />
                                            <Button
                                                Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}"
                                                Click="DeleteSongButton_Click"
                                                CommandParameter="{x:Bind}">
                                                <SymbolIcon
                                                    Symbol="Delete"
                                                    Foreground="{Binding CreatedBy, Converter={StaticResource CreatorToForegroundBrushConverter}}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
